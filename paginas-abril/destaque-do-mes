<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Jogador Destaque do Mês — ABRIL/2026</title>
  <style>
    :root{
      --bg1:#0b1020;
      --bg2:#0f1b3a;
      --card:rgba(255,255,255,.08);
      --card2:rgba(255,255,255,.06);
      --stroke:rgba(255,255,255,.14);
      --text:rgba(255,255,255,.92);
      --muted:rgba(255,255,255,.72);
      --green:#1fe58f;
      --red:#ff5d6c;
      --yellow:#ffd166;
      --blue:#3aa0ff;
      --shadow: 0 20px 60px rgba(0,0,0,.45);
      --radius: 18px;
    }

    *{box-sizing:border-box}
    body{
      margin:0;
      font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial, "Apple Color Emoji","Segoe UI Emoji";
      color:var(--text);
      background:
        radial-gradient(900px 500px at 20% 10%, rgba(31,229,143,.20), transparent 55%),
        radial-gradient(800px 500px at 85% 15%, rgba(255,93,108,.18), transparent 55%),
        radial-gradient(900px 650px at 50% 95%, rgba(255,209,102,.14), transparent 55%),
        linear-gradient(180deg, var(--bg1), var(--bg2));
      min-height:100vh;
      padding:28px 14px 60px;
    }

    .wrap{max-width:1050px;margin:0 auto;}

    header{
      display:flex;
      align-items:flex-start;
      justify-content:space-between;
      gap:16px;
      margin-bottom:18px;
    }

    .title{
      display:flex;
      flex-direction:column;
      gap:8px;
    }

    .badge{
      display:inline-flex;
      align-items:center;
      gap:10px;
      width:fit-content;
      padding:8px 12px;
      border-radius:999px;
      background:rgba(255,255,255,.08);
      border:1px solid var(--stroke);
      backdrop-filter: blur(10px);
      box-shadow: 0 8px 30px rgba(0,0,0,.25);
      font-size:13px;
      color:var(--muted);
    }
    .dot{
      width:10px;height:10px;border-radius:50%;
      background: linear-gradient(135deg, var(--yellow), var(--green));
      box-shadow: 0 0 0 4px rgba(255,209,102,.12);
    }

    h1{
      margin:0;
      font-size:28px;
      line-height:1.15;
      letter-spacing:.2px;
    }

    .title-trophy{
      display:inline-block;
      margin-left:6px;
      transform-origin:50% 100%;
      animation:trophy-bounce 1.1s ease-in-out infinite;
    }

    @keyframes trophy-bounce{
      0%, 100%{transform:translateY(0) rotate(0deg);}
      25%{transform:translateY(-9px) rotate(-8deg);}
      50%{transform:translateY(0) rotate(0deg);}
      75%{transform:translateY(-5px) rotate(6deg);}
    }

    .title-star{
      display:inline-block;
      margin-right:8px;
      transform-origin:50% 50%;
      animation:star-grow-spin 1.5s linear infinite;
    }

    @keyframes star-grow-spin{
      0%{transform:rotate(0deg) scale(1);}
      25%{transform:rotate(90deg) scale(1.18);}
      50%{transform:rotate(180deg) scale(1.34);}
      75%{transform:rotate(270deg) scale(1.18);}
      100%{transform:rotate(360deg) scale(1);}
    }

    @media (prefers-reduced-motion: reduce){
      .title-trophy,
      .title-star,
      .eligible li.winnerRow,
      .eligible li.winnerRow::after{animation:none;}
    }

    .subtitle{
      margin:0;
      color:var(--muted);
      font-size:14px;
      line-height:1.45;
      max-width:75ch;
    }

    .grid{
      display:grid;
      grid-template-columns: repeat(12, 1fr);
      gap:14px;
    }

    .card{
      grid-column: span 12;
      border-radius: var(--radius);
      background: linear-gradient(180deg, var(--card), var(--card2));
      border:1px solid var(--stroke);
      box-shadow: var(--shadow);
      overflow:hidden;
      position:relative;
    }

    .card::before{
      content:"";
      position:absolute;
      inset:0;
      background:
        radial-gradient(520px 220px at 20% 0%, rgba(255,209,102,.16), transparent 60%),
        radial-gradient(520px 220px at 80% 0%, rgba(31,229,143,.12), transparent 60%),
        radial-gradient(520px 260px at 50% 110%, rgba(58,160,255,.10), transparent 60%);
      pointer-events:none;
    }

    .card-head{
      position:relative;
      padding:16px 18px 14px;
      border-bottom:1px solid rgba(255,255,255,.10);
      background:rgba(0,0,0,.10);
      backdrop-filter: blur(10px);
      display:flex;
      align-items:flex-start;
      justify-content:space-between;
      gap:14px;
    }

    .meta{
      display:flex;
      gap:10px;
      flex-wrap:wrap;
      align-items:center;
      justify-content:flex-end;
    }

    .chip{
      display:inline-flex;
      align-items:center;
      gap:8px;
      padding:7px 10px;
      border-radius:999px;
      border:1px solid rgba(255,255,255,.14);
      background:rgba(255,255,255,.06);
      color:var(--muted);
      font-size:12px;
      white-space:nowrap;
    }
    .chip b{color:var(--text); font-weight:800}
    .ico{
      width:10px;height:10px;border-radius:50%;
    }
    .ico.gold{background:rgba(255,209,102,.95)}
    .ico.green{background:rgba(31,229,143,.85)}
    .ico.blue{background:rgba(58,160,255,.85)}

    .card-body{
      position:relative;
      padding:18px;
    }

    .hero{
      display:grid;
      grid-template-columns: repeat(12, 1fr);
      gap:14px;
      align-items:stretch;
    }

    .winner{
      grid-column: span 12;
      border-radius: 16px;
      border:1px solid rgba(255,255,255,.12);
      background:rgba(255,255,255,.05);
      padding:16px;
      overflow:hidden;
      position:relative;
    }
    .winner::before{
      content:"";
      position:absolute;
      inset:-40px -60px auto auto;
      width:260px;height:260px;
      background: radial-gradient(circle at 30% 30%, rgba(255,209,102,.35), transparent 55%);
      transform: rotate(18deg);
      pointer-events:none;
    }

    .winner-top{
      display:flex;
      align-items:flex-start;
      justify-content:space-between;
      gap:12px;
      flex-wrap:wrap;
    }
    .crown{
      width:46px;height:46px;
      display:grid;place-items:center;
      border-radius:14px;
      border:1px solid rgba(255,255,255,.14);
      background:rgba(255,209,102,.10);
      box-shadow: 0 10px 30px rgba(0,0,0,.25);
      font-size:22px;
    }

    .winner h2{
      margin:0;
      font-size:16px;
      letter-spacing:.2px;
      color:var(--muted);
      text-transform:uppercase;
    }

    .name{
      margin:6px 0 8px;
      font-size:34px;
      letter-spacing:.6px;
      font-weight:900;
    }

    .votes{
      display:inline-flex;
      align-items:center;
      gap:8px;
      padding:10px 12px;
      border-radius:999px;
      border:1px solid rgba(255,255,255,.14);
      background:rgba(255,255,255,.06);
      color:var(--text);
      font-weight:800;
      width:fit-content;
    }
    .votes .spark{
      width:10px;height:10px;border-radius:50%;
      background: linear-gradient(135deg, var(--yellow), var(--green));
      box-shadow: 0 0 0 4px rgba(255,209,102,.12);
    }

    .checklist{
      margin-top:14px;
      display:grid;
      grid-template-columns: repeat(12, 1fr);
      gap:10px;
    }

    .check{
      grid-column: span 12;
      display:flex;
      align-items:flex-start;
      gap:10px;
      padding:10px 12px;
      border-radius:14px;
      border:1px solid rgba(255,255,255,.12);
      background:rgba(255,255,255,.04);
      color:rgba(255,255,255,.88);
    }
    .check .mark{
      flex:0 0 auto;
      width:26px;height:26px;
      border-radius:10px;
      display:grid;place-items:center;
      border:1px solid rgba(255,255,255,.16);
      background:rgba(31,229,143,.10);
      color:rgba(31,229,143,.95);
      font-weight:900;
    }
    .check p{margin:2px 0 0;color:var(--muted);font-size:12px}
    .check strong{display:block;font-size:14px;color:var(--text);}

    @media (min-width: 860px){
      .winner{grid-column: span 8;}
      .side{grid-column: span 4;}
      .check{grid-column: span 6;}
    }

    .side{
      grid-column: span 12;
      border-radius:16px;
      border:1px solid rgba(255,255,255,.12);
      background:rgba(255,255,255,.05);
      padding:16px;
      overflow:hidden;
      position:relative;
    }
    .side h3{
      margin:0 0 10px;
      font-size:13px;
      text-transform:uppercase;
      letter-spacing:.35px;
      color:var(--muted);
    }

    .eligible{
      list-style:none;
      padding:0;
      margin:0;
      display:grid;
      gap:8px;
    }

    .eligible li{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:10px;
      padding:10px 12px;
      border-radius:14px;
      border:1px solid rgba(255,255,255,.12);
      background:rgba(255,255,255,.04);
      font-weight:700;
    }

    .eligible li .tag{
      font-size:12px;
      color:var(--muted);
      font-weight:700;
      padding:4px 8px;
      border-radius:999px;
      border:1px solid rgba(255,255,255,.14);
      background:rgba(255,255,255,.06);
    }
    .eligible li.winnerRow{
      position:relative;
      overflow:hidden;
      border-color: rgba(255,209,102,.56);
      background: linear-gradient(135deg, rgba(255,209,102,.20), rgba(255,209,102,.08));
      box-shadow: 0 0 0 0 rgba(255,209,102,.00), 0 0 18px rgba(255,209,102,.18);
      transform-origin:center center;
      animation:winner-row-pulse 2.4s ease-in-out infinite;
    }
    .eligible li.winnerRow::after{
      content:"";
      position:absolute;
      inset:-1px;
      border-radius:inherit;
      pointer-events:none;
      box-shadow:
        inset 0 0 16px rgba(255,209,102,.18),
        0 0 24px rgba(255,209,102,.22);
      opacity:.55;
      animation:winner-row-glow 2.4s ease-in-out infinite;
    }
    .eligible li.winnerRow .tag{
      color:rgba(255,255,255,.95);
      border-color: rgba(255,209,102,.50);
      background: rgba(255,209,102,.16);
    }

    @keyframes winner-row-pulse{
      0%, 100%{
        transform:scale(1);
        box-shadow: 0 0 0 0 rgba(255,209,102,.00), 0 0 16px rgba(255,209,102,.16);
      }
      50%{
        transform:scale(1.02);
        box-shadow: 0 0 0 6px rgba(255,209,102,.08), 0 0 26px rgba(255,209,102,.34);
      }
    }

    @keyframes winner-row-glow{
      0%, 100%{opacity:.45;}
      50%{opacity:.95;}
    }

    .hashes{
      margin-top:12px;
      display:flex;
      flex-wrap:wrap;
      gap:8px;
    }
    .hash{
      font-size:12px;
      color:rgba(255,255,255,.78);
      padding:7px 10px;
      border-radius:999px;
      border:1px solid rgba(255,255,255,.14);
      background:rgba(255,255,255,.06);
      white-space:nowrap;
    }

    footer{
      margin-top:18px;
      color:rgba(255,255,255,.55);
      font-size:12px;
      text-align:center;
    }

    .confetti-canvas{
      position:fixed;
      inset:0;
      width:100vw;
      height:100vh;
      pointer-events:none;
      z-index:999;
    }
  </style>
</head>
<body>
  <canvas id="confetti-canvas" class="confetti-canvas" aria-hidden="true"></canvas>
  <div class="wrap">
    <header>
      <div class="title">
        <div class="badge"><span class="dot"></span> Premiação oficial da Patota</div>
        <h1>Jogador Destaque do Mês <span class="title-trophy" aria-hidden="true">🏆</span></h1>
        <p class="subtitle">
          Resultado final após avaliação da galera, seguindo os critérios oficiais.
        </p>
      </div>
    </header>

    <section class="grid">
      <article class="card">
        <div class="card-head">
          <div>
            <div style="font-weight:800; font-size:14px; color:rgba(255,255,255,.86);">
              Resultado da votação
            </div>
            <div style="margin-top:6px; color:var(--muted); font-size:12px;">
              ABRIL/2026 • Patota Perebas FC
            </div>
          </div>

          <div class="meta" aria-label="Resumo">
            <span class="chip"><span class="ico gold"></span> <b>Vencedor:</b> Leone</span>
            <span class="chip"><span class="ico blue"></span> <b>Votos:</b> 3</span>
            <span class="chip"><span class="ico green"></span> <b>Elegíveis:</b> 9</span>
          </div>
        </div>

        <div class="card-body">
          <div class="hero">
            <!-- Winner -->
            <section class="winner">
              <div class="winner-top">
                <div>
                  <h2><span class="title-star" aria-hidden="true">⭐</span>Destaque do mês</h2>
                  <div class="name">LEONE</div>
                  <div class="votes"><span class="spark"></span> Total de votos: <span aria-label="votos">3</span></div>
                </div>
                <div class="crown" aria-hidden="true">👑</div>
              </div>

              <div class="checklist" aria-label="Critérios atendidos">
                <div class="check">
                  <div class="mark">✓</div>
                  <div>
                    <strong>Presença em todos os jogos</strong>
                    <p>Compromisso e participação total no ciclo.</p>
                  </div>
                </div>
                <div class="check">
                  <div class="mark">✓</div>
                  <div>
                    <strong>Impacto coletivo no time</strong>
                    <p>Jogou pro time e elevou o nível do grupo.</p>
                  </div>
                </div>
                <div class="check">
                  <div class="mark">✓</div>
                  <div>
                    <strong>Regularidade durante o mês</strong>
                    <p>Manteve alto desempenho em todos os jogos.</p>
                  </div>
                </div>
                <div class="check">
                  <div class="mark">✓</div>
                  <div>
                    <strong>Espírito de equipe</strong>
                    <p>Postura, incentivo e resenha com responsa.</p>
                  </div>
                </div>
              </div>

              <div style="margin-top:14px; color:rgba(255,255,255,.88); font-weight:700;">
                Parabéns pelo desempenho e pelo comprometimento dentro de campo! 👊⚽
              </div>

              <div class="hashes" aria-label="Hashtags">
                <span class="hash">#PatotaPerebasFC</span>
                <span class="hash">#JogadorDoMes</span>
                <span class="hash">#ResenhaComResponsa</span>
                <span class="hash">#PatoteiroRaiz</span>
              </div>
            </section>

            <!-- Eligible -->
            <aside class="side">
              <h3>🏆 Elegíveis — ABRIL 2026</h3>
              <ul class="eligible">
                <li><span>Cleberson</span><span class="tag">Elegível</span></li>
                <li><span>Chico</span><span class="tag">Elegível</span></li>
                <li><span>Daniel</span><span class="tag">Elegível</span></li>
                <li><span>Elias</span><span class="tag">Elegível</span></li>
                <li><span>Everton</span><span class="tag">Elegível</span></li>
                <li><span>Henrique</span><span class="tag">Elegível</span></li>
                <li><span>Jean</span><span class="tag">Elegível</span></li>
                <li class="winnerRow"><span>Leone</span><span class="tag">Vencedor</span></li>
                <li><span>Tácio</span><span class="tag">Elegível</span></li>
              </ul>

              <div style="margin-top:12px; color:var(--muted); font-size:12px;">
                👉 Total: <b style="color:var(--text)">9</b> jogadores elegíveis
              </div>
            </aside>
          </div>
        </div>
      </article>
    </section>

    <footer>
      Feito para celebrar a resenha ⚽ — ABRIL/2026
    </footer>
  </div>
  <script>
    (function () {
      var canvas = document.getElementById("confetti-canvas");
      if (!canvas) return;

      if (window.matchMedia && window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
        canvas.remove();
        return;
      }

      var ctx = canvas.getContext("2d");
      if (!ctx) return;

      var dpr = Math.min(window.devicePixelRatio || 1, 2);
      var width = 0;
      var height = 0;
      var particles = [];
      var rafId = 0;
      var colors = ["#ffd166", "#1fe58f", "#3aa0ff", "#ff5d6c", "#ffffff"];

      function resizeCanvas() {
        width = window.innerWidth;
        height = window.innerHeight;
        canvas.width = Math.floor(width * dpr);
        canvas.height = Math.floor(height * dpr);
        canvas.style.width = width + "px";
        canvas.style.height = height + "px";
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      }

      function spawnConfetti() {
        var total = Math.max(360, Math.floor(width * 0.6));
        var originX = width * 0.5;
        var originY = -24;

        for (var i = 0; i < total; i++) {
          var angle = Math.PI * (0.04 + Math.random() * 0.92);
          var speed = 4 + Math.random() * 8;
          particles.push({
            x: originX,
            y: originY,
            vx: Math.cos(angle) * speed * (1 + Math.random() * 0.8),
            vy: Math.abs(Math.sin(angle) * speed) + 1.8,
            w: 5 + Math.random() * 7,
            h: 6 + Math.random() * 10,
            rotation: Math.random() * Math.PI,
            spin: (Math.random() - 0.5) * 0.35,
            alpha: 1,
            fade: 0.0016 + Math.random() * 0.0022,
            color: colors[Math.floor(Math.random() * colors.length)]
          });
        }
      }

      function cleanup() {
        if (rafId) cancelAnimationFrame(rafId);
        window.removeEventListener("resize", resizeCanvas);
        canvas.remove();
      }

      function animate() {
        var active = 0;
        ctx.clearRect(0, 0, width, height);

        for (var i = 0; i < particles.length; i++) {
          var p = particles[i];
          if (p.alpha <= 0 || p.y > height + 40) continue;

          p.vx *= 0.996;
          p.vy = p.vy * 0.996 + 0.14;
          p.x += p.vx;
          p.y += p.vy;
          p.rotation += p.spin;
          p.alpha -= p.fade;

          ctx.save();
          ctx.globalAlpha = p.alpha < 0 ? 0 : p.alpha;
          ctx.translate(p.x, p.y);
          ctx.rotate(p.rotation);
          ctx.fillStyle = p.color;
          ctx.fillRect(-p.w / 2, -p.h / 2, p.w, p.h);
          ctx.restore();

          active++;
        }

        if (active > 0) {
          rafId = requestAnimationFrame(animate);
          return;
        }

        cleanup();
      }

      resizeCanvas();
      window.addEventListener("resize", resizeCanvas, { passive: true });
      spawnConfetti();
      animate();
    })();
  </script>
</body>
</html>

